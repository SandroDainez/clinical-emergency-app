{
  "buildCommand": "npx expo export -p web",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/modulos/(.*)",
      "destination": "/modulos/[id].html"
    },
    {
      "source": "/session-history/(.*)",
      "destination": "/session-history/[sessionId].html"
    }
  ]
}
