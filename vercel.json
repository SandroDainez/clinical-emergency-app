{
  "buildCommand": "npx expo export -p web",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/modulos/(.*)",
      "destination": "/modulos/%5Bid%5D"
    },
    {
      "source": "/session-history/(.*)",
      "destination": "/session-history/%5BsessionId%5D"
    }
  ]
}
